// ╔══════════════════════════════════════════════════════════════════╗
// ║  INSTITUTIONAL FLOW v3  —  NQ / NASDAQ  (Pine Script v5)        ║
// ║  SET CHART TO 15M  |  overlay=true  |  Non-Repainting           ║
// ║  4H Trend · 1H Trade · 15M Entry · VWAP · Liq · OB · FVG       ║
// ║  + Trailing Stop · BOS/CHoCH · Displacement · Premium/Discount  ║
// ║  + Session Kill Zones · Score /8 · Enhanced Dashboard           ║
// ╚══════════════════════════════════════════════════════════════════╝
//@version=5
indicator("Institutional Flow v3 [NQ MTF]", shorttitle="IF·NQ·v3", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=400)

// ════════════════════════════════════════════════════════════
//  INPUTS
// ════════════════════════════════════════════════════════════
grpMTF    = "── Timeframes ──"
tf_trend  = input.timeframe("240", "Trend TF (4H)", group=grpMTF)
tf_trade  = input.timeframe("60",  "Trade TF (1H)", group=grpMTF)

grpVol    = "── Volume ──"
volLen    = input.int(20,    "Volume MA Length",         minval=5,  group=grpVol)
volMult   = input.float(1.5, "Institutional Spike Mult", step=0.1,  group=grpVol)

grpLiq    = "── Liquidity ──"
swingLen  = input.int(10,    "Swing Pivot Length",       minval=3,  group=grpLiq)
liqLookbk = input.int(50,    "Liquidity Lookback",       minval=20, group=grpLiq)

grpOB     = "── Order Blocks ──"
obStrength = input.float(1.2, "OB Vol Strength",         step=0.1,  group=grpOB)

grpSig    = "── Signal Quality ──"
minScore  = input.int(4,     "Min Confirmations (3-8)",  minval=3, maxval=8, group=grpSig)

grpRM     = "── Risk Management ──"
rrRatio        = input.float(2.0, "R:R Ratio",                step=0.5,  group=grpRM)
atrLen         = input.int(14,    "ATR Length",                minval=5,  group=grpRM)
slMult         = input.float(1.0, "SL ATR Multiplier",         step=0.1,  group=grpRM)
trailActivation= input.float(1.0, "Trail Activate (ATR mult)", step=0.1,  group=grpRM, tooltip="How far price must move in your favour before trailing stop activates")
trailAtrMult   = input.float(0.8, "Trail Distance (ATR mult)", step=0.1,  group=grpRM, tooltip="Trailing stop distance from current price in ATR units")

grpSess   = "── Session Kill Zones ──"
showKZ    = input.bool(true,  "Show Kill Zones (London / NY)", group=grpSess)
tzSession = input.string("America/New_York", "Timezone", group=grpSess)

grpVis    = "── Display ──"
showVWAP  = input.bool(true,  "Show VWAP + Bands",    group=grpVis)
showAVWAP = input.bool(true,  "Show Anchored VWAP",   group=grpVis)
showOB    = input.bool(true,  "Show Order Blocks",    group=grpVis)
showFVG   = input.bool(true,  "Show Fair Value Gaps", group=grpVis)
showLiq   = input.bool(true,  "Show Liquidity",       group=grpVis)
showSwing = input.bool(true,  "Show Swing Levels",    group=grpVis)
showMS    = input.bool(true,  "Show BOS / CHoCH",     group=grpVis)
showDisp  = input.bool(true,  "Show Displacement",    group=grpVis)
showDash  = input.bool(true,  "Show Dashboard",       group=grpVis)
showTPSL  = input.bool(true,  "Show TP / SL Lines",   group=grpVis)
showTrail = input.bool(true,  "Show Trailing Stop",   group=grpVis)
showLvlBox= input.bool(true,  "Show Levels Box",      group=grpVis)

// ════════════════════════════════════════════════════════════
//  COLOURS
// ════════════════════════════════════════════════════════════
C_BULL  = #00e676
C_BEAR  = #ff1744
C_GOLD  = #ffd600
C_VWAP  = #29b6f6
C_WHITE = #e0e0e0
C_GRAY  = #546e7a
C_OB_B  = color.new(#1565c0, 75)
C_OB_S  = color.new(#b71c1c, 75)
C_FVG_B = color.new(#00e676, 90)
C_FVG_S = color.new(#ff1744, 90)
C_TRAIL = #ff9800
C_BOS   = #ab47bc
C_CHOCH = #ef5350
C_DISP  = color.new(#ffd600, 88)
C_LDN   = color.new(#1565c0, 93)
C_NY    = color.new(#006064, 93)

// ════════════════════════════════════════════════════════════
//  HTF — confirmed bars only, no lookahead
// ════════════════════════════════════════════════════════════
f_htf(tf, src) => request.security(syminfo.tickerid, tf, src[1], lookahead=barmerge.lookahead_off)

// ════════════════════════════════════════════════════════════
//  4H TREND
// ════════════════════════════════════════════════════════════
h4_close  = f_htf(tf_trend, close)
h4_high   = f_htf(tf_trend, high)
h4_low    = f_htf(tf_trend, low)
h4_ema20  = f_htf(tf_trend, ta.ema(close, 20))
h4_ema50  = f_htf(tf_trend, ta.ema(close, 50))
h4_ema200 = f_htf(tf_trend, ta.ema(close, 200))
h4_vwap   = f_htf(tf_trend, ta.vwap(hlc3))

h4_bull      = h4_close > h4_ema20 and h4_ema20 > h4_ema50 and h4_ema50 > h4_ema200
h4_bear      = h4_close < h4_ema20 and h4_ema20 < h4_ema50 and h4_ema50 < h4_ema200
h4_HH        = h4_high > h4_high[1] and h4_high[1] > h4_high[2]
h4_LL        = h4_low  < h4_low[1]  and h4_low[1]  < h4_low[2]
h4_uptrend   = h4_bull and h4_HH and h4_close > h4_vwap
h4_downtrend = h4_bear and h4_LL and h4_close < h4_vwap

// ════════════════════════════════════════════════════════════
//  1H TRADE
// ════════════════════════════════════════════════════════════
h1_close  = f_htf(tf_trade, close)
h1_open   = f_htf(tf_trade, open)
h1_high   = f_htf(tf_trade, high)
h1_low    = f_htf(tf_trade, low)
h1_vol    = f_htf(tf_trade, volume)
h1_volMA  = f_htf(tf_trade, ta.sma(volume, volLen))
h1_ema9   = f_htf(tf_trade, ta.ema(close, 9))
h1_ema21  = f_htf(tf_trade, ta.ema(close, 21))
h1_rsi    = f_htf(tf_trade, ta.rsi(close, 14))
h1_vwap   = f_htf(tf_trade, ta.vwap(hlc3))

h1_range   = math.max(h1_high - h1_low, 0.0001)
h1_bullBar = h1_close > h1_open and (h1_close - h1_low) / h1_range > 0.66 and h1_vol > h1_volMA
h1_bearBar = h1_close < h1_open and (h1_high - h1_close) / h1_range > 0.66 and h1_vol > h1_volMA
h1_emaUp   = h1_ema9 > h1_ema21 and h1_close > h1_ema21 and h1_close > h1_vwap
h1_emaDn   = h1_ema9 < h1_ema21 and h1_close < h1_ema21 and h1_close < h1_vwap
h1_momUp   = h1_rsi > 50 and h1_rsi < 75
h1_momDn   = h1_rsi < 50 and h1_rsi > 25

// ════════════════════════════════════════════════════════════
//  SESSION VWAP + BANDS
// ════════════════════════════════════════════════════════════
vwap15  = ta.vwap(hlc3)
vwapDev = math.sqrt(ta.sma(math.pow(hlc3 - vwap15, 2), 20))
vwapU1  = vwap15 + vwapDev
vwapL1  = vwap15 - vwapDev
vwapU2  = vwap15 + vwapDev * 2
vwapL2  = vwap15 - vwapDev * 2

plot(showVWAP ? vwap15 : na, "VWAP",     color=C_VWAP,                linewidth=2)
plot(showVWAP ? vwapU1 : na, "VWAP +1s", color=color.new(C_VWAP, 55), linewidth=1)
plot(showVWAP ? vwapL1 : na, "VWAP -1s", color=color.new(C_VWAP, 55), linewidth=1)
plot(showVWAP ? vwapU2 : na, "VWAP +2s", color=color.new(C_VWAP, 78), linewidth=1)
plot(showVWAP ? vwapL2 : na, "VWAP -2s", color=color.new(C_VWAP, 78), linewidth=1)

aboveVWAP = close > vwap15
belowVWAP = close < vwap15

// ════════════════════════════════════════════════════════════
//  ANCHORED VWAP
// ════════════════════════════════════════════════════════════
pivotHigh = ta.pivothigh(high, swingLen, swingLen)
pivotLow  = ta.pivotlow(low,   swingLen, swingLen)

var float avwap_sumPV_bull = 0.0
var float avwap_sumV_bull  = 0.0
var float avwap_sumPV_bear = 0.0
var float avwap_sumV_bear  = 0.0

if not na(pivotLow)
    avwap_sumPV_bull := 0.0
    avwap_sumV_bull  := 0.0

if not na(pivotHigh)
    avwap_sumPV_bear := 0.0
    avwap_sumV_bear  := 0.0

avwap_sumPV_bull := avwap_sumPV_bull + hlc3 * volume
avwap_sumV_bull  := avwap_sumV_bull  + volume
avwap_sumPV_bear := avwap_sumPV_bear + hlc3 * volume
avwap_sumV_bear  := avwap_sumV_bear  + volume

avwap_bull = avwap_sumV_bull > 0 ? avwap_sumPV_bull / avwap_sumV_bull : na
avwap_bear = avwap_sumV_bear > 0 ? avwap_sumPV_bear / avwap_sumV_bear : na

plot(showAVWAP ? avwap_bull : na, "AVWAP (Bull anchor)", color=color.new(C_BULL, 30), linewidth=1)
plot(showAVWAP ? avwap_bear : na, "AVWAP (Bear anchor)", color=color.new(C_BEAR, 30), linewidth=1)

aboveAVWAP = not na(avwap_bull) and close > avwap_bull
belowAVWAP = not na(avwap_bear) and close < avwap_bear

// ════════════════════════════════════════════════════════════
//  SWING LEVELS
// ════════════════════════════════════════════════════════════
var float lastSwingHi = na
var float lastSwingLo = na
var line  swingHiLine = na
var line  swingLoLine = na

if not na(pivotHigh)
    lastSwingHi := high[swingLen]
    if not na(swingHiLine)
        line.delete(swingHiLine)
    if showSwing
        swingHiLine := line.new(x1=bar_index - swingLen, y1=lastSwingHi, x2=bar_index, y2=lastSwingHi, xloc=xloc.bar_index, extend=extend.right, color=color.new(C_GOLD, 45), width=1, style=line.style_dotted)

if not na(pivotLow)
    lastSwingLo := low[swingLen]
    if not na(swingLoLine)
        line.delete(swingLoLine)
    if showSwing
        swingLoLine := line.new(x1=bar_index - swingLen, y1=lastSwingLo, x2=bar_index, y2=lastSwingLo, xloc=xloc.bar_index, extend=extend.right, color=color.new(C_GOLD, 45), width=1, style=line.style_dotted)

// ════════════════════════════════════════════════════════════
//  ATR + VOLUME
// ════════════════════════════════════════════════════════════
atr15   = ta.atr(atrLen)
volMA15 = ta.sma(volume, volLen)
instVol = volume > volMA15 * volMult
avgVol  = volume > volMA15

slDist = atr15 * slMult
tpDist = slDist * rrRatio

// ════════════════════════════════════════════════════════════
//  PREMIUM / DISCOUNT ZONES  (ICT / SMC Layer)
// ════════════════════════════════════════════════════════════
rangeLen   = 50
rangeHigh  = ta.highest(high, rangeLen)
rangeLow   = ta.lowest(low,   rangeLen)
rangeMid   = (rangeHigh + rangeLow) / 2
inDiscount = close < rangeMid   // favour longs
inPremium  = close > rangeMid   // favour shorts

// ════════════════════════════════════════════════════════════
//  SESSION KILL ZONES  (London 3-5 AM ET, NY 9:30-11 AM ET)
// ════════════════════════════════════════════════════════════
inLondonKZ = not na(time(timeframe.period, "0300-0500", tzSession))
inNYKZ     = not na(time(timeframe.period, "0930-1100", tzSession))
inKillZone = inLondonKZ or inNYKZ

bgcolor(showKZ and inLondonKZ ? C_LDN : na, title="London Kill Zone")
bgcolor(showKZ and inNYKZ     ? C_NY  : na, title="NY Kill Zone")

// ════════════════════════════════════════════════════════════
//  MARKET STRUCTURE  (BOS / CHoCH)
// ════════════════════════════════════════════════════════════
// Track last confirmed swing highs/lows for BOS detection
var float msBullSwingHi = na
var float msBullSwingLo = na
var float msBearSwingHi = na
var float msBearSwingLo = na
var int   lastBullMSBar = 0
var int   lastBearMSBar = 0

// Update swing references
if not na(pivotHigh) and barstate.isconfirmed
    msBearSwingHi := high[swingLen]
if not na(pivotLow) and barstate.isconfirmed
    msBullSwingLo := low[swingLen]

// BOS = break in direction of trend (continuation)
// CHoCH = break against previous structure (reversal signal)
bos_bull  = not na(msBearSwingHi) and close > msBearSwingHi and close[1] <= msBearSwingHi and h4_uptrend   and barstate.isconfirmed
bos_bear  = not na(msBullSwingLo) and close < msBullSwingLo and close[1] >= msBullSwingLo and h4_downtrend and barstate.isconfirmed
choch_bull = not na(msBullSwingLo) and close < msBullSwingLo and close[1] >= msBullSwingLo and h4_uptrend   and barstate.isconfirmed
choch_bear = not na(msBearSwingHi) and close > msBearSwingHi and close[1] <= msBearSwingHi and h4_downtrend and barstate.isconfirmed

if bos_bull and showMS and barstate.isconfirmed
    label.new(bar_index, high + atr15 * 0.4, "BOS", style=label.style_none, textcolor=C_BOS, size=size.tiny)
if bos_bear and showMS and barstate.isconfirmed
    label.new(bar_index, low - atr15 * 0.4, "BOS", style=label.style_none, textcolor=C_BOS, size=size.tiny)
if choch_bull and showMS and barstate.isconfirmed
    label.new(bar_index, low - atr15 * 0.7, "CHoCH ⚠", style=label.style_none, textcolor=C_CHOCH, size=size.tiny)
if choch_bear and showMS and barstate.isconfirmed
    label.new(bar_index, high + atr15 * 0.7, "CHoCH ⚠", style=label.style_none, textcolor=C_CHOCH, size=size.tiny)

// For dashboard
hasMS_bull = bos_bull
hasMS_bear = bos_bear

// ════════════════════════════════════════════════════════════
//  DISPLACEMENT  (Institutional signature candles)
// ════════════════════════════════════════════════════════════
dispBody    = math.abs(close - open)
dispBullBar = close > open and dispBody > atr15 * 2.0 and close > high[1] and barstate.isconfirmed
dispBearBar = close < open and dispBody > atr15 * 2.0 and close < low[1]  and barstate.isconfirmed

bgcolor(showDisp and dispBullBar ? C_DISP : na, title="Bull Displacement")
bgcolor(showDisp and dispBearBar ? C_DISP : na, title="Bear Displacement")

if dispBullBar and showDisp and barstate.isconfirmed
    label.new(bar_index, low - atr15 * 0.8, "DISP↑", style=label.style_none, textcolor=C_GOLD, size=size.tiny)
if dispBearBar and showDisp and barstate.isconfirmed
    label.new(bar_index, high + atr15 * 0.8, "DISP↓", style=label.style_none, textcolor=C_GOLD, size=size.tiny)

// ════════════════════════════════════════════════════════════
//  LIQUIDITY POOLS
// ════════════════════════════════════════════════════════════
liqThresh    = atr15 * 0.15
highestHigh  = ta.highest(high, liqLookbk)
lowestLow    = ta.lowest(low,   liqLookbk)
equalHighs   = math.abs(high - highestHigh) < liqThresh and high[1] > high[2] and high[1] > high[0]
equalLows    = math.abs(low  - lowestLow)   < liqThresh and low[1]  < low[2]  and low[1]  < low[0]
bullLiqSweep = low < lowestLow[1]    and close > lowestLow[1]    and instVol
bearLiqSweep = high > highestHigh[1] and close < highestHigh[1]  and instVol

if equalHighs and showLiq and barstate.isconfirmed
    label.new(bar_index - 1, high[1] + atr15 * 0.3, "SSL", style=label.style_none, textcolor=color.new(C_BEAR, 20), size=size.tiny)
if equalLows and showLiq and barstate.isconfirmed
    label.new(bar_index - 1, low[1] - atr15 * 0.3, "BSL", style=label.style_none, textcolor=color.new(C_BULL, 20), size=size.tiny)
if bullLiqSweep and showLiq and barstate.isconfirmed
    label.new(bar_index, low - atr15 * 0.6, "SWEEP", style=label.style_none, textcolor=C_GOLD, size=size.tiny)
if bearLiqSweep and showLiq and barstate.isconfirmed
    label.new(bar_index, high + atr15 * 0.6, "SWEEP", style=label.style_none, textcolor=C_GOLD, size=size.tiny)

// ════════════════════════════════════════════════════════════
//  ORDER BLOCKS
// ════════════════════════════════════════════════════════════
isBullOB = close[1] < open[1] and close > open and close > high[1] and volume > volMA15 * obStrength and barstate.isconfirmed
isBearOB = close[1] > open[1] and close < open and close < low[1]  and volume > volMA15 * obStrength and barstate.isconfirmed

var float ob_bull_hi  = na
var float ob_bull_lo  = na
var float ob_bear_hi  = na
var float ob_bear_lo  = na
var box   ob_bull_box = na
var box   ob_bear_box = na

if isBullOB
    ob_bull_hi := math.max(open[1], close[1])
    ob_bull_lo := math.min(open[1], close[1])
    if not na(ob_bull_box)
        box.delete(ob_bull_box)
    if showOB
        ob_bull_box := box.new(left=bar_index - 1, top=ob_bull_hi, right=bar_index, bottom=ob_bull_lo, xloc=xloc.bar_index, extend=extend.right, border_color=C_BULL, bgcolor=C_OB_B, border_width=1)

if isBearOB
    ob_bear_hi := math.max(open[1], close[1])
    ob_bear_lo := math.min(open[1], close[1])
    if not na(ob_bear_box)
        box.delete(ob_bear_box)
    if showOB
        ob_bear_box := box.new(left=bar_index - 1, top=ob_bear_hi, right=bar_index, bottom=ob_bear_lo, xloc=xloc.bar_index, extend=extend.right, border_color=C_BEAR, bgcolor=C_OB_S, border_width=1)

inBullOB = not na(ob_bull_lo) and close >= ob_bull_lo and close <= ob_bull_hi
inBearOB = not na(ob_bear_lo) and close >= ob_bear_lo and close <= ob_bear_hi

// ════════════════════════════════════════════════════════════
//  FAIR VALUE GAPS
// ════════════════════════════════════════════════════════════
bullFVG = low > high[2] and barstate.isconfirmed
bearFVG = high < low[2]  and barstate.isconfirmed

if bullFVG and showFVG
    box.new(left=bar_index - 2, top=low, right=bar_index, bottom=high[2], xloc=xloc.bar_index, extend=extend.none, border_color=color.new(C_BULL, 50), bgcolor=C_FVG_B, border_width=1)
if bearFVG and showFVG
    box.new(left=bar_index - 2, top=low[2], right=bar_index, bottom=high, xloc=xloc.bar_index, extend=extend.none, border_color=color.new(C_BEAR, 50), bgcolor=C_FVG_S, border_width=1)

// ════════════════════════════════════════════════════════════
//  15M ENTRY
// ════════════════════════════════════════════════════════════
totalRange = math.max(high - low, 0.0001)
bodyRatio  = math.abs(close - open) / totalRange
bull15     = close > open and bodyRatio > 0.6 and (close - low) / totalRange > 0.6 and avgVol
bear15     = close < open and bodyRatio > 0.6 and (high - close) / totalRange > 0.6 and avgVol
bullEngulf = close > open and close > high[1] and open < low[1] and avgVol
bearEngulf = close < open and close < low[1]  and open > high[1] and avgVol

ema9_15  = ta.ema(close, 9)
ema21_15 = ta.ema(close, 21)
ema50_15 = ta.ema(close, 50)
ema15Up  = ema9_15 > ema21_15 and ema21_15 > ema50_15
ema15Dn  = ema9_15 < ema21_15 and ema21_15 < ema50_15

rsi15    = ta.rsi(close, 14)
rsi15Up  = rsi15 > 50 and rsi15 < 72
rsi15Dn  = rsi15 < 50 and rsi15 > 28

macdLine = ta.ema(close, 12) - ta.ema(close, 26)
signLine = ta.ema(macdLine, 9)
macdHist = macdLine - signLine
macd15Up = macdHist > 0 and macdHist > macdHist[1]
macd15Dn = macdHist < 0 and macdHist < macdHist[1]

// ════════════════════════════════════════════════════════════
//  SIGNAL SCORING  (8 layers)
// ════════════════════════════════════════════════════════════
L1 = h4_uptrend ? 1 : 0
L2 = h1_bullBar and h1_emaUp ? 1 : 0
L3 = h1_momUp ? 1 : 0
L4 = (bull15 or bullEngulf or bullLiqSweep) and ema15Up ? 1 : 0
L5 = instVol and (macd15Up or rsi15Up) ? 1 : 0
L6 = aboveVWAP and aboveAVWAP ? 1 : 0
L7 = inBullOB or bullLiqSweep ? 1 : 0
L8 = inDiscount ? 1 : 0   // ICT Premium / Discount
longScore = L1 + L2 + L3 + L4 + L5 + L6 + L7 + L8

S1 = h4_downtrend ? 1 : 0
S2 = h1_bearBar and h1_emaDn ? 1 : 0
S3 = h1_momDn ? 1 : 0
S4 = (bear15 or bearEngulf or bearLiqSweep) and ema15Dn ? 1 : 0
S5 = instVol and (macd15Dn or rsi15Dn) ? 1 : 0
S6 = belowVWAP and belowAVWAP ? 1 : 0
S7 = inBearOB or bearLiqSweep ? 1 : 0
S8 = inPremium ? 1 : 0    // ICT Premium / Discount
shortScore = S1 + S2 + S3 + S4 + S5 + S6 + S7 + S8

// ════════════════════════════════════════════════════════════
//  FINAL SIGNALS
// ════════════════════════════════════════════════════════════
longRaw  = longScore  >= minScore and barstate.isconfirmed
shortRaw = shortScore >= minScore and barstate.isconfirmed

var int lastSig = 0
longSignal  = longRaw  and lastSig != 1
shortSignal = shortRaw and lastSig != -1

if longSignal
    lastSig := 1
if shortSignal
    lastSig := -1

// ════════════════════════════════════════════════════════════
//  TRAILING STOP ENGINE
// ════════════════════════════════════════════════════════════
var float trailStop     = na
var float trailEntry    = na
var int   trailDir      = 0
var bool  trailActive   = false
var bool  trailHit      = false

trailDist = atr15 * trailAtrMult

// Reset / start on new signal
if longSignal
    trailEntry  := close
    trailStop   := close - slDist
    trailDir    := 1
    trailActive := false
    trailHit    := false

if shortSignal
    trailEntry  := close
    trailStop   := close + slDist
    trailDir    := -1
    trailActive := false
    trailHit    := false

// Advance trail
if trailDir == 1 and not na(trailEntry)
    // Activate trail once price moves trailActivation × ATR in favour
    if close >= trailEntry + atr15 * trailActivation
        trailActive := true
    if trailActive
        newTrail = high - trailDist
        trailStop := math.max(trailStop, newTrail)
    // Check if stopped out
    if low <= trailStop
        trailHit  := true
        trailDir  := 0
        trailEntry := na

if trailDir == -1 and not na(trailEntry)
    if close <= trailEntry - atr15 * trailActivation
        trailActive := true
    if trailActive
        newTrail = low + trailDist
        trailStop := math.min(trailStop, newTrail)
    if high >= trailStop
        trailHit  := true
        trailDir  := 0
        trailEntry := na

// Plot trailing stop line
plot(showTrail and trailDir != 0 ? trailStop : na, "Trail Stop", color=trailActive ? C_TRAIL : color.new(C_TRAIL, 60), linewidth=2, style=plot.style_stepline)

// ════════════════════════════════════════════════════════════
//  TP / SL LINES
// ════════════════════════════════════════════════════════════
var line tp_line    = na
var line sl_line    = na
var line entry_line = na

if (longSignal or shortSignal) and showTPSL
    if not na(tp_line)
        line.delete(tp_line)
    if not na(sl_line)
        line.delete(sl_line)
    if not na(entry_line)
        line.delete(entry_line)
    tp_val     = longSignal ? close + tpDist : close - tpDist
    sl_val     = longSignal ? close - slDist : close + slDist
    tp_line    := line.new(x1=bar_index, y1=tp_val, x2=bar_index + 1, y2=tp_val, xloc=xloc.bar_index, extend=extend.right, color=color.new(C_BULL, 0), width=2, style=line.style_dashed)
    sl_line    := line.new(x1=bar_index, y1=sl_val, x2=bar_index + 1, y2=sl_val, xloc=xloc.bar_index, extend=extend.right, color=color.new(C_BEAR, 0), width=2, style=line.style_dashed)
    entry_line := line.new(x1=bar_index, y1=close,  x2=bar_index + 1, y2=close,  xloc=xloc.bar_index, extend=extend.right, color=color.new(C_GOLD, 0), width=1, style=line.style_dotted)

// ════════════════════════════════════════════════════════════
//  STORE LAST SIGNAL LEVELS
// ════════════════════════════════════════════════════════════
var float lastEntry = na
var float lastTP    = na
var float lastSL    = na
var int   lastDir   = 0

if longSignal
    lastEntry := close
    lastSL    := close - slDist
    lastTP    := close + tpDist
    lastDir   := 1

if shortSignal
    lastEntry := close
    lastSL    := close + slDist
    lastTP    := close - tpDist
    lastDir   := -1

// ════════════════════════════════════════════════════════════
//  SIGNAL LABELS
// ════════════════════════════════════════════════════════════
scoreTag(s) => s >= 7 ? "[S+]" : s == 5 or s == 6 ? "[A+]" : s == 4 ? "[A]" : "[B]"

if longSignal and barstate.isconfirmed
    _slVal  = str.tostring(math.round(close - slDist, 1))
    _tpVal  = str.tostring(math.round(close + tpDist, 1))
    _trVal  = str.tostring(math.round(close - slDist, 1))
    label.new(bar_index, low - atr15 * 1.5,
      "▲ LONG " + scoreTag(longScore) + "  " + str.tostring(longScore) + "/8\n" +
      "Entry  : " + str.tostring(math.round(close, 1)) + "\n" +
      "SL     : " + _slVal + "\n" +
      "TP     : " + _tpVal + "\n" +
      "Trail  : ATR×" + str.tostring(trailAtrMult) + " | Act@+" + str.tostring(trailActivation) + "ATR",
      style=label.style_label_up, color=color.new(#0d47a1, 0), textcolor=color.white, size=size.small)

if shortSignal and barstate.isconfirmed
    _slVal  = str.tostring(math.round(close + slDist, 1))
    _tpVal  = str.tostring(math.round(close - tpDist, 1))
    label.new(bar_index, high + atr15 * 1.5,
      "▼ SHORT " + scoreTag(shortScore) + "  " + str.tostring(shortScore) + "/8\n" +
      "Entry  : " + str.tostring(math.round(close, 1)) + "\n" +
      "SL     : " + _slVal + "\n" +
      "TP     : " + _tpVal + "\n" +
      "Trail  : ATR×" + str.tostring(trailAtrMult) + " | Act@-" + str.tostring(trailActivation) + "ATR",
      style=label.style_label_down, color=color.new(#b71c1c, 0), textcolor=color.white, size=size.small)

// ════════════════════════════════════════════════════════════
//  EMA PLOTS + BACKGROUND
// ════════════════════════════════════════════════════════════
plot(ema9_15,  "EMA 9",  color=color.new(#29b6f6, 0), linewidth=1)
plot(ema21_15, "EMA 21", color=color.new(#ce93d8, 0), linewidth=1)
plot(ema50_15, "EMA 50", color=color.new(C_GOLD,  0), linewidth=2)

bgcolor(h4_uptrend ? color.new(C_BULL, 97) : h4_downtrend ? color.new(C_BEAR, 97) : na, title="4H Trend Background")

// ════════════════════════════════════════════════════════════
//  HELPER FUNCTIONS
// ════════════════════════════════════════════════════════════
yesNo(v)    => v ? "YES" : "NO"
yesClr(v)   => v ? C_BULL : color.new(C_BEAR, 30)
gradeClr(s) => s >= 7 ? C_GOLD : s >= 5 ? C_BULL : s >= 3 ? C_BEAR : C_GRAY

// ════════════════════════════════════════════════════════════
//  DASHBOARD VARIABLES
// ════════════════════════════════════════════════════════════
sigTxt   = longSignal ? "▲ LONG" : shortSignal ? "▼ SHORT" : "— WAIT"
sigClr   = longSignal ? C_BULL   : shortSignal  ? C_BEAR    : C_GRAY
volPct   = str.tostring(math.round(volume / volMA15 * 100)) + "%"
volTxt   = instVol ? "INSTITUTIONAL" : avgVol ? "ABOVE AVG" : "LOW"
volClr   = instVol ? C_GOLD : avgVol ? C_BULL : C_GRAY
vwapDist = str.tostring(math.round(math.abs(close - vwap15) / atr15 * 10) / 10) + "x ATR"
liqTxt   = bullLiqSweep ? "BULL SWEEP" : bearLiqSweep ? "BEAR SWEEP" : equalHighs ? "SELL LIQ" : equalLows ? "BUY LIQ" : "—"
liqClr   = bullLiqSweep ? C_BULL : bearLiqSweep ? C_BEAR : C_GRAY
l15e     = (bull15 or bullEngulf or bullLiqSweep) and ema15Up
s15e     = (bear15 or bearEngulf or bearLiqSweep) and ema15Dn
lvm      = instVol and (macd15Up or rsi15Up)
svm      = instVol and (macd15Dn or rsi15Dn)
kzTxt    = inLondonKZ ? "LONDON" : inNYKZ ? "NEW YORK" : "OFF"
kzClr    = inLondonKZ ? #42a5f5 : inNYKZ ? #26c6da : C_GRAY
pdTxt_l  = inDiscount ? "DISCOUNT ✓" : "PREMIUM ✗"
pdTxt_s  = inPremium  ? "PREMIUM ✓"  : "DISCOUNT ✗"
pdClr_l  = inDiscount ? C_BULL : color.new(C_BEAR, 30)
pdClr_s  = inPremium  ? C_BULL : color.new(C_BEAR, 30)
msTxt_l  = bos_bull  ? "BOS ▲" : choch_bull ? "CHoCH ⚠" : "—"
msTxt_s  = bos_bear  ? "BOS ▼" : choch_bear ? "CHoCH ⚠" : "—"
msClr_l  = bos_bull  ? C_BOS  : choch_bull ? C_CHOCH  : C_GRAY
msClr_s  = bos_bear  ? C_BOS  : choch_bear ? C_CHOCH  : C_GRAY
trailTxt = trailDir != 0 and not na(trailStop) ? (trailActive ? "ACTIVE " : "ARMED  ") + str.tostring(math.round(trailStop, 1)) : "—"
trailClr = trailActive ? C_TRAIL : trailDir != 0 ? color.new(C_TRAIL, 50) : C_GRAY

// ════════════════════════════════════════════════════════════
//  MAIN DASHBOARD  (top right)
// ════════════════════════════════════════════════════════════
if showDash and barstate.islast
    var table dash = table.new(position.top_right, 3, 17, bgcolor=color.new(#060612, 5), border_color=color.new(#1a2a3a, 0), border_width=1, frame_color=#1a2a3a, frame_width=2)
    // Header
    table.cell(dash, 0, 0, "INSTITUTIONAL FLOW v3", text_color=C_GOLD,  text_size=size.small, bgcolor=color.new(#0d1b2a, 0), text_halign=text.align_center)
    table.cell(dash, 1, 0, "NQ  |  MTF",            text_color=C_WHITE, text_size=size.small, bgcolor=color.new(#0d1b2a, 0), text_halign=text.align_center)
    table.cell(dash, 2, 0, timeframe.period + "M",  text_color=C_GRAY,  text_size=size.tiny,  bgcolor=color.new(#0d1b2a, 0))
    // Column labels
    table.cell(dash, 0, 1, "LAYER",  text_color=C_GRAY, text_size=size.tiny, bgcolor=color.new(#111122, 0))
    table.cell(dash, 1, 1, "LONG",   text_color=C_BULL, text_size=size.tiny, bgcolor=color.new(#111122, 0))
    table.cell(dash, 2, 1, "SHORT",  text_color=C_BEAR, text_size=size.tiny, bgcolor=color.new(#111122, 0))
    // Rows
    table.cell(dash, 0, 2,  "4H Trend",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 2,  yesNo(h4_uptrend),   text_color=yesClr(h4_uptrend),   text_size=size.tiny)
    table.cell(dash, 2, 2,  yesNo(h4_downtrend), text_color=yesClr(h4_downtrend), text_size=size.tiny)
    table.cell(dash, 0, 3,  "1H Structure",      text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 3,  yesNo(h1_bullBar and h1_emaUp), text_color=yesClr(h1_bullBar and h1_emaUp), text_size=size.tiny)
    table.cell(dash, 2, 3,  yesNo(h1_bearBar and h1_emaDn), text_color=yesClr(h1_bearBar and h1_emaDn), text_size=size.tiny)
    table.cell(dash, 0, 4,  "1H Momentum",       text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 4,  yesNo(h1_momUp), text_color=yesClr(h1_momUp), text_size=size.tiny)
    table.cell(dash, 2, 4,  yesNo(h1_momDn), text_color=yesClr(h1_momDn), text_size=size.tiny)
    table.cell(dash, 0, 5,  "15M Entry",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 5,  yesNo(l15e), text_color=yesClr(l15e), text_size=size.tiny)
    table.cell(dash, 2, 5,  yesNo(s15e), text_color=yesClr(s15e), text_size=size.tiny)
    table.cell(dash, 0, 6,  "Vol + Mom",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 6,  yesNo(lvm), text_color=yesClr(lvm), text_size=size.tiny)
    table.cell(dash, 2, 6,  yesNo(svm), text_color=yesClr(svm), text_size=size.tiny)
    table.cell(dash, 0, 7,  "VWAP",              text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 7,  yesNo(aboveVWAP and aboveAVWAP), text_color=yesClr(aboveVWAP and aboveAVWAP), text_size=size.tiny)
    table.cell(dash, 2, 7,  yesNo(belowVWAP and belowAVWAP), text_color=yesClr(belowVWAP and belowAVWAP), text_size=size.tiny)
    table.cell(dash, 0, 8,  "OB / Liq",          text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 8,  yesNo(inBullOB or bullLiqSweep), text_color=yesClr(inBullOB or bullLiqSweep), text_size=size.tiny)
    table.cell(dash, 2, 8,  yesNo(inBearOB or bearLiqSweep), text_color=yesClr(inBearOB or bearLiqSweep), text_size=size.tiny)
    table.cell(dash, 0, 9,  "Premium/Disc",      text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 9,  pdTxt_l, text_color=pdClr_l, text_size=size.tiny)
    table.cell(dash, 2, 9,  pdTxt_s, text_color=pdClr_s, text_size=size.tiny)
    table.cell(dash, 0, 10, "Mkt Structure",     text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 10, msTxt_l, text_color=msClr_l, text_size=size.tiny)
    table.cell(dash, 2, 10, msTxt_s, text_color=msClr_s, text_size=size.tiny)
    table.cell(dash, 0, 11, "Kill Zone",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 11, kzTxt,  text_color=kzClr,  text_size=size.tiny)
    table.cell(dash, 2, 11, inKillZone ? "✓ ACTIVE" : "—", text_color=inKillZone ? C_GOLD : C_GRAY, text_size=size.tiny)
    // Score
    table.cell(dash, 0, 12, "SCORE /8",          text_color=C_GOLD,  text_size=size.small, bgcolor=color.new(#0d1b2a, 0))
    table.cell(dash, 1, 12, str.tostring(longScore)  + " / 8", text_color=gradeClr(longScore),  text_size=size.small, bgcolor=color.new(#0d1b2a, 0))
    table.cell(dash, 2, 12, str.tostring(shortScore) + " / 8", text_color=gradeClr(shortScore), text_size=size.small, bgcolor=color.new(#0d1b2a, 0))
    // Signal
    table.cell(dash, 0, 13, "SIGNAL",            text_color=C_GOLD,  text_size=size.small)
    table.cell(dash, 1, 13, sigTxt,               text_color=sigClr,  text_size=size.small)
    table.cell(dash, 2, 13, "min: " + str.tostring(minScore), text_color=C_GRAY, text_size=size.tiny)
    // Trail stop
    table.cell(dash, 0, 14, "Trail Stop",        text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 14, trailTxt,             text_color=trailClr, text_size=size.tiny)
    table.cell(dash, 2, 14, trailDir == 1 ? "LONG" : trailDir == -1 ? "SHORT" : "—", text_color=trailDir == 1 ? C_BULL : trailDir == -1 ? C_BEAR : C_GRAY, text_size=size.tiny)
    // VWAP dist
    table.cell(dash, 0, 15, "VWAP dist",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 15, aboveVWAP ? "ABOVE" : "BELOW", text_color=aboveVWAP ? C_BULL : C_BEAR, text_size=size.tiny)
    table.cell(dash, 2, 15, vwapDist,             text_color=C_GRAY,  text_size=size.tiny)
    // Liquidity
    table.cell(dash, 0, 16, "Liquidity",         text_color=C_WHITE, text_size=size.tiny)
    table.cell(dash, 1, 16, liqTxt,               text_color=liqClr,  text_size=size.tiny)
    table.cell(dash, 2, 16, volPct,                text_color=volClr,  text_size=size.tiny)

// ════════════════════════════════════════════════════════════
//  TRADE LEVELS BOX  (bottom right)
// ════════════════════════════════════════════════════════════
if showLvlBox and barstate.islast and not na(lastEntry)
    var table lvl = table.new(position.bottom_right, 2, 9, bgcolor=color.new(#060612, 5), border_color=color.new(#1a2a3a, 0), border_width=1, frame_color=#1a2a3a, frame_width=2)
    dirTxt  = lastDir == 1 ? "▲  LONG" : "▼  SHORT"
    dirClr  = lastDir == 1 ? C_BULL : C_BEAR
    slPts   = str.tostring(math.round(math.abs(lastEntry - lastSL), 1))
    tpPts   = str.tostring(math.round(math.abs(lastTP - lastEntry), 1))
    rrTxt   = "1 : " + str.tostring(rrRatio)
    atrTxt  = str.tostring(math.round(atr15, 1)) + " pts"
    trailLvl = trailDir != 0 and not na(trailStop) ? str.tostring(math.round(trailStop, 1)) : "—"
    trailSt  = trailActive ? "TRAILING" : trailDir != 0 ? "ARMED" : "—"
    table.cell(lvl, 0, 0, "LAST SIGNAL LEVELS", text_color=C_GOLD,  text_size=size.small, bgcolor=color.new(#0d1b2a, 0), text_halign=text.align_center)
    table.cell(lvl, 1, 0, dirTxt,               text_color=dirClr,  text_size=size.small, bgcolor=color.new(#0d1b2a, 0))
    table.cell(lvl, 0, 1, "Entry",              text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 1, str.tostring(math.round(lastEntry, 1)), text_color=C_GOLD,  text_size=size.small)
    table.cell(lvl, 0, 2, "Stop Loss",          text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 2, str.tostring(math.round(lastSL, 1)) + "  (-" + slPts + " pts)", text_color=C_BEAR, text_size=size.small)
    table.cell(lvl, 0, 3, "Take Profit",        text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 3, str.tostring(math.round(lastTP, 1)) + "  (+" + tpPts + " pts)", text_color=C_BULL, text_size=size.small)
    table.cell(lvl, 0, 4, "Trail Stop",         text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 4, trailLvl,              text_color=C_TRAIL, text_size=size.small)
    table.cell(lvl, 0, 5, "Trail Status",       text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 5, trailSt,               text_color=trailClr, text_size=size.tiny)
    table.cell(lvl, 0, 6, "R:R",                text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 6, rrTxt,                 text_color=C_WHITE, text_size=size.tiny)
    table.cell(lvl, 0, 7, "ATR",                text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 7, atrTxt,                text_color=C_WHITE, text_size=size.tiny)
    table.cell(lvl, 0, 8, "Score",              text_color=C_GRAY,  text_size=size.tiny)
    table.cell(lvl, 1, 8, str.tostring(lastDir == 1 ? longScore : shortScore) + " / 8", text_color=C_GOLD, text_size=size.tiny)

// ════════════════════════════════════════════════════════════
//  ALERTS
// ════════════════════════════════════════════════════════════
alertcondition(longSignal,                "IF·NQ LONG",          "LONG signal — {{ticker}} {{interval}}")
alertcondition(shortSignal,               "IF·NQ SHORT",         "SHORT signal — {{ticker}} {{interval}}")
alertcondition(longSignal or shortSignal, "IF·NQ Any Signal",    "Signal — {{ticker}} {{interval}}")
alertcondition(bullLiqSweep,              "IF·NQ Bull Sweep",    "Bull liquidity sweep — {{ticker}}")
alertcondition(bearLiqSweep,              "IF·NQ Bear Sweep",    "Bear liquidity sweep — {{ticker}}")
alertcondition(bos_bull,                  "IF·NQ BOS Bull",      "Bullish BOS — {{ticker}}")
alertcondition(bos_bear,                  "IF·NQ BOS Bear",      "Bearish BOS — {{ticker}}")
alertcondition(choch_bull or choch_bear,  "IF·NQ CHoCH",         "Change of Character — {{ticker}}")
alertcondition(trailHit,                  "IF·NQ Trail Stop Hit","Trail stop hit — {{ticker}}")
alertcondition(dispBullBar or dispBearBar,"IF·NQ Displacement",  "Institutional displacement — {{ticker}}")